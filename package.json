{
  "name": "npmxers",
  "type": "module",
  "scripts": {
    "dev": "nuxt dev",
    "build": "nuxt build",
    "lint": "eslint .",
    "collect:contributors": "tsx scripts/collect-contributors.ts",
    "postinstall": "nuxt prepare",
    "test:browser": "playwright test test/browser",
    "test:browser:update": "docker run --rm --network host -v $(pwd):/work/ -v /tmp/playwright-node-modules:/work/node_modules -w /work/ -it mcr.microsoft.com/playwright:v1.55.1-noble bash -c 'corepack enable && pnpm i && pnpm playwright test test/browser --update-snapshots'",
    "test:nuxt": "vitest --project nuxt",
    "test:types": "vue-tsc -b --noEmit",
    "test:unit": "vitest --project unit"
  },
  "devDependencies": {
    "@iconify-json/lucide": "^1.2.115",
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/test-utils": "^4.0.3",
    "@playwright/test": "^1.61.1",
    "@types/node": "^25.9.4",
    "eslint": "^10.6.0",
    "happy-dom": "^20.10.6",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "vue-tsc": "^3.3.6"
  },
  "dependencies": {
    "@iconify-json/heroicons": "^1.2.3",
    "@iconify-json/ph": "^1.2.2",
    "@iconify-json/simple-icons": "^1.2.88",
    "@netlify/nuxt": "0.3.8",
    "@nuxt/devtools": "^3.2.4",
    "@nuxt/fonts": "^0.14.0",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@octokit/plugin-paginate-rest": "^14.0.0",
    "@octokit/plugin-retry": "^8.1.0",
    "@resvg/resvg-js": "^2.6.2",
    "@takumi-rs/core": "^1.8.7",
    "@vueuse/core": "^14.3.0",
    "@vueuse/nuxt": "^14.3.0",
    "nuxt": "^4.4.7",
    "nuxt-og-image": "^6.7.0",
    "octokit": "^5.0.5",
    "ofetch": "^1.5.1",
    "satori": "^0.26.0",
    "tailwindcss": "^4.3.2",
    "ufo": "^1.6.4",
    "uncrypto": "^0.1.3",
    "unstorage": "^1.17.5",
    "vue": "^3.5.39",
    "vue-confetti-explosion": "^1.0.2"
  },
  "packageManager": "pnpm@11.9.0"
}
